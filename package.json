    "content:clean": "node scripts/content-clean.mjs",
    "content:seed-launch": "node scripts/content-seed-launch.mjs",
    "db:studio": "prisma studio",
    "production:check": "node scripts/production-check.mjs",
    "deploy:check": "npm run production:check && npm run typecheck && npm run lint && npm run build",
    "asset:discord-thread": "node scripts/generate-discord-thread-showcase.mjs",
    "start": "next start",
    "test:flows": "node scripts/test-flows.mjs",
    "bot:dev": "tsx bot/src/index.ts",
    "bot:start": "tsx bot/src/index.ts",
    "bot:register": "tsx bot/src/register-commands.ts",
    "bot:test": "tsx bot/tests/local-bot.test.ts",
    "lint": "eslint",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@prisma/client": "^6.19.3",
    "bcryptjs": "^3.0.3",
    "clsx": "^2.1.1",
