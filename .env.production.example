# MxF Labs production environment template for IONOS VPS/Node hosting.
# Do not use local mock values in production. Store this as server environment
# variables or as a private .env file on the server, never in public web roots.

NODE_ENV="production"
CONTENT_MODE="production"
IONOS_DEPLOY_TARGET="vps"

# Core platform
DATABASE_URL="postgresql://mxf_user:strong_password@127.0.0.1:5432/mxf_labs?schema=public"
ADMIN_EMAIL="admin@mxf-labs.com"
ADMIN_PASSWORD="replace-with-a-new-admin-password"
AUTH_SECRET="replace-with-a-new-64-character-random-secret"
NEXT_PUBLIC_SITE_URL="https://mxf-labs.com"
NEXT_PUBLIC_SITE_MODE="coming-soon"
PUBLIC_SITE_MODE="coming-soon"
SUPPORT_EMAIL="support@mxf-labs.com"
FROM_EMAIL="MxF Labs <support@mxf-labs.com>"
CONTACT_TO_EMAIL="support@mxf-labs.com"
DISCORD_INVITE_URL=""
GITHUB_URL=""

# Discord OAuth + bot
DISCORD_CLIENT_ID=""
DISCORD_CLIENT_SECRET=""
DISCORD_PUBLIC_KEY=""
DISCORD_REDIRECT_URI="https://mxf-labs.com/api/auth/discord/callback"
DISCORD_BOT_TOKEN=""
DISCORD_GUILD_ID=""
DISCORD_BOT_API_KEY="replace-with-a-private-bot-api-key"
MXF_BOT_API_KEY="replace-with-the-same-private-bot-api-key"
MXF_API_BASE_URL="https://mxf-labs.com"
DISCORD_WEBHOOK_URL=""
BOT_LOCAL_MODE="false"
BOT_REGISTER_COMMANDS_ON_START="false"
BOT_HEARTBEAT_INTERVAL_SECONDS="60"

# Production safety
MOCK_PROVIDERS_ENABLED="false"
PAYMENT_PROVIDER_MODE="stripe"

# Stripe
STRIPE_SECRET_KEY=""
STRIPE_PUBLISHABLE_KEY=""
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=""
STRIPE_WEBHOOK_SECRET=""

# PayPal
PAYPAL_ENV="live"
PAYPAL_CLIENT_ID=""
PAYPAL_CLIENT_SECRET=""
PAYPAL_WEBHOOK_ID=""

# Email
RESEND_API_KEY=""

# Private product storage. Keep this outside /public and outside Apache/Nginx docroot.
STORAGE_PROVIDER="local"
LOCAL_STORAGE_ROOT="/var/www/mxf-labs/storage/products"
